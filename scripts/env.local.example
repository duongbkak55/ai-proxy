# Local-dev env file for scripts/run-local.sh.
# Copy to .test-run/env.local and fill in values.
# Never commit a filled-in copy — .test-run/ is gitignored.

# ── Proxy runtime ──────────────────────────────────────────────────────────
# Real Anthropic key (or whatever the upstream uses). Required for actual chat.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Upstream API URL. Default is Anthropic. Override to point at a regional
# endpoint, an Anthropic-compatible router (e.g. 9router), or a local mock.
# The configured host is auto-added to the upstream allow-list, so changing
# this is enough — no need to touch allowlist.urlDomains.
OMC_PROXY_UPSTREAM=https://api.anthropic.com

# Env var name the proxy reads for the upstream API key. Useful when routing
# to a non-Anthropic backend (e.g. OPENROUTER_API_KEY). Leave default unless
# you set the key under a different name above.
OMC_PROXY_API_KEY_ENV=ANTHROPIC_API_KEY

# Set to 1 ONLY when pointing at a local plaintext-HTTP mock. Default https-only.
# OMC_PROXY_ALLOW_HTTP_UPSTREAM=1

# Comma-separated origin allow-list for browser → proxy. Default covers the
# python http.server we start on :8001. Add more if hosting the demo elsewhere.
OMC_PROXY_CORS_ORIGIN=http://127.0.0.1:8001,http://localhost:8001

# Optional flag overrides — usually leave unset.
# OMC_PROXY_SQL_DLP=1
# OMC_PROXY_AST_DLP=1

# ── Demo build (chat-config.js defaults) ───────────────────────────────────
# Browser hits this URL. If proxy listen.port differs, update here too.
OMC_DEMO_PROXY_URL=http://127.0.0.1:11500

# Bearer token issued by `omc-proxy auth issue` — paste the printed plaintext.
OMC_DEMO_BEARER_TOKEN=REPLACE_ME

# Anthropic model id — see https://docs.anthropic.com/en/docs/about-claude/models
OMC_DEMO_MODEL=claude-sonnet-4-5
OMC_DEMO_MAX_TOKENS=1024
# OMC_DEMO_SYSTEM_PROMPT="You are a helpful assistant."

# ── Local ports (override if collision) ────────────────────────────────────
LOCAL_PROXY_PORT=11500
LOCAL_WEB_PORT=8001

# Path to proxy config (relative to repo root).
LOCAL_PROXY_CONFIG=.test-run/proxy.jsonc
